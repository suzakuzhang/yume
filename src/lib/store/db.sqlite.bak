import Database from "better-sqlite3";
import fs from "fs";
import path from "path";

/**
 * SQLite connection singleton. DB file lives under DATA_DIR (env), defaulting to
 * ./data. On Render, mount a persistent disk and set DATA_DIR to its mountPath so
 * the dream journal survives deploys/restarts.
 *
 * Cached on globalThis to survive Next.js dev hot-reload (avoid re-opening).
 */

const DATA_DIR = process.env.DATA_DIR?.trim() || path.join(process.cwd(), "data");

const SCHEMA = `
CREATE TABLE IF NOT EXISTS users (
  id TEXT PRIMARY KEY,
  username TEXT UNIQUE NOT NULL,
  passHash TEXT NOT NULL,
  role TEXT NOT NULL,
  inviteCodeUsed TEXT NOT NULL DEFAULT '',
  createdAt TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS sessions (
  token TEXT PRIMARY KEY,
  userId TEXT NOT NULL,
  username TEXT NOT NULL DEFAULT '',
  role TEXT NOT NULL,
  accessType TEXT NOT NULL DEFAULT '',
  createdAt TEXT NOT NULL,
  expiresAt TEXT NOT NULL
);
CREATE INDEX IF NOT EXISTS idx_sessions_user ON sessions(userId);

CREATE TABLE IF NOT EXISTS invite_codes (
  code TEXT PRIMARY KEY,
  type TEXT NOT NULL DEFAULT 'quota',
  usedCount INTEGER NOT NULL DEFAULT 0,
  maxUses INTEGER NOT NULL DEFAULT 10,
  isActive INTEGER NOT NULL DEFAULT 1,
  label TEXT NOT NULL DEFAULT '',
  createdBy TEXT NOT NULL DEFAULT '',
  createdAt TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS usage_logs (
  id TEXT PRIMARY KEY,
  timestamp TEXT NOT NULL,
  action TEXT NOT NULL,
  role TEXT NOT NULL,
  userId TEXT NOT NULL DEFAULT '',
  detail TEXT NOT NULL DEFAULT '',
  extra TEXT
);
CREATE INDEX IF NOT EXISTS idx_logs_ts ON usage_logs(timestamp);

CREATE TABLE IF NOT EXISTS dreams (
  id TEXT PRIMARY KEY,
  userId TEXT NOT NULL,
  date TEXT NOT NULL,
  imageryElements TEXT NOT NULL DEFAULT '[]',
  question TEXT NOT NULL DEFAULT '',
  dreamText TEXT NOT NULL DEFAULT '',
  mood TEXT NOT NULL DEFAULT '',
  painterlyProse TEXT NOT NULL DEFAULT '',
  imageUrl TEXT NOT NULL DEFAULT '',
  createdAt TEXT NOT NULL
);
CREATE INDEX IF NOT EXISTS idx_dreams_user ON dreams(userId, createdAt);

CREATE TABLE IF NOT EXISTS readings (
  id TEXT PRIMARY KEY,
  dreamId TEXT NOT NULL,
  userId TEXT NOT NULL,
  castResult TEXT,
  tarot TEXT,
  debate TEXT,
  synthesis TEXT,
  createdAt TEXT NOT NULL
);
CREATE INDEX IF NOT EXISTS idx_readings_dream ON readings(dreamId);
`;

type DB = Database.Database;

const globalForDb = globalThis as unknown as { __yumeDb?: DB };

function open(): DB {
  fs.mkdirSync(DATA_DIR, { recursive: true });
  const db = new Database(path.join(DATA_DIR, "yume.db"));
  db.pragma("journal_mode = WAL");
  db.pragma("foreign_keys = ON");
  db.exec(SCHEMA);
  return db;
}

export function getDb(): DB {
  if (!globalForDb.__yumeDb) {
    globalForDb.__yumeDb = open();
  }
  return globalForDb.__yumeDb;
}
