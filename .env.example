# yume environment — copy to .env.local for local dev; set these in Render for prod.

# One aihubmix key gateways every model (chat + image). Lights up tarot LLM reading,
# the generative four-lens debate, the longitudinal narrative, and (P5) image gen.
AIHUBMIX_API_KEY=
AIHUBMIX_BASE_URL=https://aihubmix.com/v1
YUME_MODEL=deepseek-chat
YUME_MODEL_FALLBACK=
YUME_IMAGE_MODEL=

# Admin console password (sent as X-Admin-Code from /admin)
YUME_ADMIN_CODE=

# "1"/"true" to require an invite code on register; unset/"0" = open beta
YUME_REQUIRE_INVITE=

# Where the JSON store lives. Local default ./data; on Render point at the mounted disk.
DATA_DIR=
